# =========================================================
# MONOREPO / NODE.JS / TURBOREPO PRODUCTION .GITIGNORE
# =========================================================

# ---------------------------------------------------------
# Dependencies
# ---------------------------------------------------------
node_modules/
**/node_modules/

.pnp
.pnp.js
.pnp.cjs
.pnp.loader.mjs

# Package manager caches
.npm/
.pnpm-store/
.pnpm-debug.log*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/sdks
!.yarn/versions
.yarn/cache
.yarn/unplugged
.yarn/build-state.yml
.yarn/install-state.gz

# ---------------------------------------------------------
# Environment Files
# ---------------------------------------------------------
.env
.env.*
!.env.example
!.env.sample

# ---------------------------------------------------------
# Build / Output Directories
# ---------------------------------------------------------
dist/
build/
out/
.next/
.nuxt/
.svelte-kit/
storybook-static/
coverage/

# Monorepo nested outputs
**/dist/
**/build/
**/out/
**/.next/
**/.nuxt/
**/.svelte-kit/
**/coverage/

# TurboRepo
.turbo/
**/.turbo/

# NX
.nx/

# Rush
common/temp/
common/autoinstallers/

# ---------------------------------------------------------
# TypeScript
# ---------------------------------------------------------
*.tsbuildinfo

# ---------------------------------------------------------
